# Transformers Whisper model (device auto-detected: cuda / mps / cpu)
TRANSFORMERS_WHISPER_MODEL_ID=ghost613/whisper-large-v3-turbo-korean

# Comma-separated frontend origins (replace with real frontend domain)
BACKEND_CORS_ORIGINS=https://your-frontend.example.com

# Production profile
# 반드시 충분히 긴 랜덤 값을 설정하세요.
BACKEND_API_KEY=replace-with-a-long-random-secret
BACKEND_REQUIRE_API_KEY=true

# Per-IP request budget per minute (in-memory)
BACKEND_RATE_LIMIT_PER_MINUTE=80
BACKEND_RATE_LIMIT_MAX_CLIENTS=10000

# Enable only when behind a trusted reverse proxy/LB
BACKEND_TRUST_PROXY_HEADERS=true

# Maximum upload payload for /api/transcribe (MB)
BACKEND_MAX_UPLOAD_MB=20

# Keep false in production unless needed for diagnostics
BACKEND_EXPOSE_HEALTH_DETAILS=false
